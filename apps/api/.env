# Database - Neon PostgreSQL
# IMPORTANT: Replace with your actual Neon connection string
# Use pooled connection for production, direct for migrations
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/eastern?sslmode=require"

# JWT Secrets
JWT_ACCESS_SECRET="dev-access-secret-at-least-32-characters-long-for-security"
JWT_REFRESH_SECRET="dev-refresh-secret-at-least-32-characters-long-for-security"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"