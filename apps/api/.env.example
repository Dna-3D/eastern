# Database - Neon PostgreSQL
# Use pooled connection string (with ?pgbouncer=true) for production
# Use direct connection (without ?pgbouncer=true) for migrations
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/eastern?sslmode=require"

# JWT Secrets
JWT_ACCESS_SECRET="your-access-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# Termii (SMS + OTP)
TERMII_API_KEY="your-termii-api-key"
TERMII_SENDER_ID="EasternGist"

# Resend (Email)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Paystack (Primary Payment)
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxx"

# Flutterwave (Fallback Payment)
FLUTTERWAVE_SECRET_KEY="FLWSECK-xxxxxxxxxxxx"
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK-xxxxxxxxxxxx"

# Redis (Upstash or Railway)
REDIS_URL="redis://default:password@usw1-xxxx.upstash.io:6379"

# Meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="your-master-key"

# OpenAI
OPENAI_API_KEY="sk-xxxxxxxxxxxx"

# Mapbox
MAPBOX_ACCESS_TOKEN="pk.xxxxxxxxxxxx"

# PostHog
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Web Push VAPID
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@easterngist.com"

# App
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"